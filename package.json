{
  "name": "trucksim-telemetry",
  "version": "1.0.0",
  "description": "Telemetry data from the scs-sdk-plugin",
  "main": "dist/main.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc",
    "test": "vitest --run src",
    "test:watch": "vitest src",
    "lint:fix": "npx eslint --fix .",
    "lint": "npx eslint .",
    "generate-docs": "npx typedoc",
    "deploy": "npm run generate-docs && npm run build && echo \"Error: Deployment not available\" && exit 1"
  },
  "gypfile": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kniffen/TruckSim-Telemetry.git"
  },
  "keywords": [
    "ats",
    "ets2",
    "scs",
    "trucksim",
    "telemetry",
    "game"
  ],
  "author": "Kniffen",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/kniffen/TruckSim-Telemetry/issues"
  },
  "homepage": "https://kniffen.dev/TruckSim-Telemetry/",
  "devDependencies": {
    "@types/node": "^24.10.4",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "eslint": "^10.5.0",
    "node-gyp": "^12.1.0",
    "rimraf": "^6.1.2",
    "typedoc": "^0.28.15",
    "typedoc-github-theme": "^0.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.50.0",
    "vitest": "^4.1.9"
  }
}
